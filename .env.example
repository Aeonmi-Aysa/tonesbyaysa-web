# Environment Variables Template
# Copy this to .env and fill in your actual values

# Stripe (optional - only if using payments)
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_KEY_HERE
STRIPE_SECRET_KEY=sk_live_YOUR_KEY_HERE
STRIPE_PRICE_WEEKLY=price_YOUR_WEEKLY_PRICE_ID
STRIPE_PRICE_LIFETIME=price_YOUR_LIFETIME_PRICE_ID
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# Supabase (required for auth/storage/migrations)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=public-anon-key-goes-here
# Only used for local scripts / Supabase CLI migrations
SUPABASE_SERVICE_ROLE_KEY=service-role-key-goes-here

# Copy this file to .env and replace placeholders with real keys.
